#!/bin/sh
# $Id$

# perform basic timing tests
# results suitable for inclusion in ports.doc
# pb 6/4/94

echo 'Date:'
date
echo ''
echo 'who am i:'
who am i
echo ''
echo 'uname -a:'
uname -a
echo ''
echo 'ls -l config.m4 xsnobol4:'
ls -l config.m4 xsnobol4
echo ''
echo 'size xsnobol4:'
size xsnobol4

echo ''
echo 'timing run of genc.sno:'

## NOTE: return value is returned by xsnobol4;
TDIR=timdir.$$
(
	rm -rf $TDIR
	mkdir $TDIR
	ln xsnobol4 procs global.procs v311.sil genc.sno snobol4.c $TDIR
	cd $TDIR
# NOTE! 2>&1 *BEFORE* >x
	time ./xsnobol4 genc.sno 2>&1 >x
	diff snobol4.c x
	cd ..
	rm -rf $TDIR
) | ./xsnobol4 -bs timing.sno
