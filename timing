#!/bin/sh
# $Id$

# perform basic timing tests
# results suitable for inclusion in ports.doc
# pb 6/4/94

if [ "$*" ]; then
	SNOBOL=$1
	shift
	ARGS="$*"
else
	SNOBOL=./xsnobol4
fi

echo 'Date:'
date
echo ''
echo 'who am i:'
who am i
echo ''
for p in `echo $PATH | tr : ' '`; do
	if [ -f $p/uname ]; then
		UNAME=$p/uname
		break
	fi
done
if [ "$UNAME" ]; then
	echo 'uname -a:'
	$UNAME -a
	echo ''

	# show hardware, if we know how;
	case `$UNAME` in
	IRIX*)
		echo 'hinv:'
		hinv
		echo ''
		;;
	SunOS)
		echo 'sunmodel:'
		./sunmodel
		echo ''
		;;
	esac
fi
#
echo 'config.guess:'
./config.guess
echo ''
echo "ls -l config.m4 ${SNOBOL}:"
ls -l config.m4 $SNOBOL
echo ''
echo 'config.m4:'
cat config.m4
echo ''
echo "size ${SNOBOL}:"
size $SNOBOL

if [ -x /usr/bin/uptime ]; then
	echo ''
	echo 'uptime:'
	/usr/bin/uptime
elif [ -x /usr/ucb/uptime ]; then
	echo ''
	echo 'uptime:'
	/usr/ucb/uptime
fi

echo ''
echo 'timing run of genc.sno:'
if [ "$ARGS" ]; then
	echo "	args: $ARGS"
fi

TDIR=timdir.$$
(
	rm -rf $TDIR
	mkdir $TDIR
	cd $TDIR
	trap "cd ..; rm -rf $TDIR; exit 1" 1 2 15

LNFILES='../xsnobol4 ../procs ../globals ../v311.sil ../genc.sno ../snobol4.c'
# AFS doesn't allow hard links across directories!
	ln $LNFILES . || ln -s $LNFILES .

# make sure "." first in path, .. second
	PATH=".:..:$PATH"
	export PATH

# NOTE! 2>&1 *BEFORE* >x
	time $SNOBOL $ARGS -s genc.sno < v311.sil 2>&1 >x
	echo ==== diff
	diff snobol4.c x

	cd ..
	rm -rf $TDIR
) | $SNOBOL -b timing.sno
# NOTE: do not add commands here; ./xsnobol4 exit status is shell exit status!!
