#!/bin/sh
# $Id$

# perform basic timing tests
# results suitable for inclusion in ports.doc
# pb 6/4/94

echo 'Date:'
date
echo ''
echo 'who am i:'
who am i
echo ''
echo 'uname -a:'
uname -a
echo ''
echo 'ls -l config.m4 xsnobol4:'
ls -l config.m4 xsnobol4
echo ''
echo 'config.m4:'
cat config.m4
echo '===== end config.m4 ====='
echo ''
echo 'size xsnobol4:'
size xsnobol4

echo ''
echo 'timing run of genc.sno:'

## NOTE: return value is returned by xsnobol4;
TDIR=timdir.$$
(
	rm -rf $TDIR
	mkdir $TDIR
	cd $TDIR
LNFILES='../xsnobol4 ../procs ../global.procs ../v311.sil ../genc.sno ../snobol4.c'
# AFS doesn't allow hard links across directories!
	ln $LNFILES . || ln -s $LNFILES .
	
# NOTE! 2>&1 *BEFORE* >x
	time ./xsnobol4 genc.sno 2>&1 >x
	echo ==== diff
	diff snobol4.c x

	cd ..
	rm -rf $TDIR
) | ./xsnobol4 -bs timing.sno
# NOTE: do not add commands here; xsnobol4 exit status is shell exit status!!
