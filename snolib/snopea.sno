#!/usr/bin/env snobol4 -b
* snopea -- a tiny "pod2man" for SNOBOL4
	sp.version = '$Id$'

* NOTE!  The directives are only inspired by "POD" format
-include 'basename.sno'

* character entity handling... A mishmash of troff and HTML!
	snopea.charpats = TABLE()

	snopea.charmaps = TABLE()
	snopea.charpats['roff'] = "''" | "``" |
+			'&lt;' | '&gt;' | '&pi;' | '&amp;'
	snopea.charmaps['roff'] = snopea.charmap.roff = TABLE()
	snopea.charmap.roff["``"] = '\*(lq'
	snopea.charmap.roff["''"] = '\*(rq'
	snopea.charmap.roff["&lt;"] = '<'
	snopea.charmap.roff["&gt;"] = '>'
	snopea.charmap.roff["&pi;"] = '\*(pi'
	snopea.charmap.roff["&amp;"] = '&'

	snopea.charpats['html'] = "''" | "``"  | '\' ANY("-.'&|")
	snopea.charmaps['html'] = snopea.charmap.html = TABLE()
	snopea.charmap.html["``"] = '&ldquo;'
	snopea.charmap.html["''"] = '&rdquo;'
	snopea.charmap.html["\'"] = "'"
	snopea.charmap.html["\."] = '.'
	snopea.charmap.html["\-"] = '-'
	snopea.charmap.html["\&"] = ''
	snopea.charmap.html["\|"] = '&thinsp;'

	DEFINE('snopea(ifile,ofile,page,sect,format)'
+			'font,efont,endlist,lsep,pre,chr,ctab'
+			'date,text,snomod,line,inpod,needspace,'
+			'oline,text,iunit,ounit,lbl,cmd') :(snopea.end)
snopea
	iunit = IO_FINDUNIT()
	INPUT(.in, iunit,, ifile)			:F(FRETURN)
	ounit = IO_FINDUNIT()
	OUTPUT(.out, ounit,, ofile)			:S(sp.begin)

	ENDFILE(iunit)
	DETACH(.in)					:(FRETURN)

sp.begin
	TERMINAL = IDENT(page) "snopea: need page name"	:S(FRETURN)
	TERMINAL = IDENT(sect) "snopea: need section"	:S(FRETURN)
	format = IDENT(format) 'html'

	page = REPLACE(page, &LCASE, &UCASE)
	date = DATE(2)
	date BREAK(' ') . date
	format = IDENT(format) 'roff'
	cmd = 'head'					:(sp.dispatch2)

sp.top	line = in					:F(sp.saweof)
	line POS(0) SPAN('*') =
	cmd = 'XXX'
	line POS(0) '=' SPAN(&LCASE) . cmd REM . rest	:S(sp.cmd)
	IDENT(inpod)					:S(sp.top)
	IDENT(line)					:S(sp.eop)
	cmd = DIFFER(needspace) 'para'			:S(sp.cmd)

* handle text, process fonts
sp.text
	oline =
sp.lloop
	line POS(0) BREAKX('BIC') . pre 
+			ANY('BIC') . font '<' BREAK('>') . txt '>' =
+							:f(sp.ldone)
	cmd = 'font'					:(sp.dispatch)

* perform character substitutions
sp.ldone
	line = oline line
	oline =
sp.cloop
	line POS(0) ARB . pre snopea.charpats[format] . chr = :f(sp.cdone)
	oline = oline pre snopea.charmaps[format][chr]	:(sp.cloop)

sp.cdone
	out = oline line
sp.out	out = vdiffer(lsep)
	text = 1
	:(sp.top)

* saw end of input file
sp.saweof
	cmd = 'eof'					:(sp.dispatch)

* saw end of paragraph (blank line)
sp.eop	needspace = text
	text =						:(sp.top)

sp.dispatch
	rest =
sp.cmd	rest SPAN(' ') =
	inpod = 1
sp.dispatch2
	lsep =
	lbl = 'sp.' format '.' cmd
	LABEL(lbl)					:S($lbl)
	TERMINAL = 'Unknown command ' cmd		:(sp.top)

sp.eof
	ENDFILE(iunit)
	ENDFILE(ounit)
	DETACH(.in)
	DETACH(.out)					:(return)

****************
* commands for *roff:

sp.roff.head
	out = '.\" generated by ' sp.version

*	if nroff, give "ragged right" output':
	out = '.if n .ad l'
	out = ".ie '\*[.T]'ascii' \{\"
	out = '.	ds lq \&"\"'
	out = '.	ds rq \&"\"'
	out = ".	ds pi \fIpi\fP"
	out = ".\}"
	out = ".el \{\"
	out = ".	ds rq ''"
	out = ".	ds lq ``"
	out = ".	ds pi \[*p]"
	out = ".\}"

*	disable hyphenation:
	out = '.nh'

	out = '.TH ' page ' ' sect ' "' date '" "SNOBOL4"'

	indent = 4
	text =
	regfont = '\fR'					:(sp.top)

sp.roff.pod						:(sp.top)

sp.roff.para
	out = ".PP"
	needspace =					:(sp.text)

sp.roff.cut
	inpod =						:(sp.top)

sp.roff.font
	font = (IDENT(font, 'C') '\f(CW', '\f' font)
	oline = oline pre font txt '\fP'		:(sp.lloop)

sp.roff.sect
	rest POS(0) SPAN(' ') =
	out = '.SH "' rest '"'
	out = '.nh'
	needspace = 1					:(sp.top)

* set indent level for items
sp.roff.indent
	indent = rest
	needspace =					:(sp.top)

sp.roff.item
	out = '.TP ' indent
	needspace =
	line = rest					:(sp.text)

* bullet item
sp.roff.bull
	out = '.IP \(bu'
	needspace =
	line = rest					:(sp.text)

sp.roff.code
* constant width font:
	out = '.ft CW'
* fresh line
	out = '.br'
* need 10 lines (soft page break):
	out = '.ne 10'
* indent:
	out = '.RS ' indent
* no hyphenation, formatting:
	out = '.nh'
	out = '.nf'					:(sp.top)

sp.roff.ecode
* back to "Roman" typeface:
	out = '.ft R'
* fill, no hyphenation:
	out = '.fi'
	out = '.nh'
* unindent:
	out = '.RE'					:(sp.top)

sp.roff.eof						:(sp.eof)

****************
* commands for html (still needs tweaking)

sp.html.head
	out = '<!-- generated by ' sp.version ' -->'

	out = '<html>'
	out = '<head>'
	out = '<title>SNOBOL4 | ' page '(' sect ') ' date '</title>'
	out = '</head>'

	out = '<h1>' page '(' sect ') ' date '</h1>'

	indent = 4
	text =

sp.html.pod						:(sp.top)

sp.html.para
	out = vdiffer(endlist)
	out = "<p>"
	needspace = endlist =				:(sp.text)

sp.html.cut						:(sp.roff.cut)

sp.html.font
	font = ident(font, 'R')				:s(sp.html.font2)
	font = ident(font, 'C') 'TT'
sp.html.font2
	efont = ident(font)				:s(sp.html.font3)
	efont = '</' font '>'
	font = '<' font '>'

sp.html.font3
	oline = oline pre font txt efont		:(sp.lloop)

sp.html.sect
	out = vdiffer(endlist)
	endlist =
	out = '<h2>' rest '</h2>'
	needspace = 1					:(sp.top)

* set indent level for items
sp.html.indent
	indent = rest
	needspace =					:(sp.top)

* definition list
sp.html.item
	differ(endlist)					:s(sp.html.item2)
	out = '<dl>'
	endlist = '</dl>'
sp.html.item2
	out = '<dt>'
	lsep = '<dd>'
	needspace =
	line = rest					:(sp.text)

* bullet item
sp.html.bull
	differ(endlist)					:s(sp.html.bull2)
	out = '<ul>'
	endlist = '</ul>'
sp.html.bull2
	out = '<li>'
	needspace =
	line = rest					:(sp.text)

sp.html.code
	out = '<pre>'					:(sp.top)

sp.html.ecode
	out = '</pre>'					:(sp.top)

sp.html.eof
	out = vdiffer(endlist)
*	output footer?  link to csnobol4 home page??
	out = '</html>'					:(sp.eof)

****************

snopea.end
