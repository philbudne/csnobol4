	&STLIMIT = &TRACE = 10000
	DEFINE("T(X,Y)")
	TRACE("STNO", "KEYWORD")
	TRACE("STCOUNT", "KEYWORD")
	BREAKPOINT(11, 1)
	BREAKPOINT(13, 1)
	BREAKPOINT(15, 1)
	BREAKPOINT(17, 1)
	LOOPS = 0
LOOP	EQ(LOOPS,2)	:S(END)
	A = 1
	A = 1
	A = 1
	A = 1
	A = 1
	A = 1
	A = 1
	A = 1
	A = 1
	BREAKPOINT(13, 0)
	BREAKPOINT(17, 0)
	LOOPS = LOOPS + 1
	:(LOOP)

T	OUTPUT = &LASTFILE ':' &LASTLINE ' ' &LASTNO	:(RETURN)
END
