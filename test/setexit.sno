	&ERRLIMIT = 1000

* Arith Error:
	setexit(.cont)
	output = 'DIVIDE: ' (1 / 0)	:f(l1)
	output = 'CONTINUE returned success?'

* Illegal Data Type:
l1	setexit(.scont)
	output = -code('OUTPUT')	:s(l2)
	output = 'SCONTINUE returned failure?'

* try before setting new handler; should be silently ignored
* Illegal Argument
l2	output = char(1000)
	output = "HERE: " &ERRTEXT

	setexit(.abrt)
* Length error
	output = len(-1)
	output = 'ABORT returned?'
	:(end)

cont	output = "cont: " &ERRTEXT	:(CONTINUE)
	output = 'CONTINUE did not branch' :(END)

scont	output = "scont: " &ERRTEXT	:(SCONTINUE)
	output = 'SCONTINUE did not branch' :(END)

abrt	output = "abrt: " &ERRTEXT	:(ABORT)
	output = 'ABORT did not branch'

end
