#!/usr/bin/env snobol4

* snopea (POD for SNOBOL4) command

-include 'host.sno'
-include 'snopea.sno'

	fmt = 'roff'

	optind = HOST(3)
optlop	opt = HOST(2, optind)			:f(usage)
	opt POS(0) '-'				:f(endopts)
	optind = optind + 1
	val = HOST(2, optind)			:f(usage)
	optind = optind + 1
	fmt = IDENT(opt, '--format') val	:s(optlop)
	fmt = IDENT(opt, '-f') val		:s(optlop)
	sect = IDENT(opt, '--section') val	:s(optlop)
	sect = IDENT(opt, '-s') val		:s(optlop)
	page = IDENT(opt, '--page') val		:s(optlop)
	page = IDENT(opt, '-p') val		:s(optlop)
	:(usage)

endopts	infile = HOST(2, optind)		:f(usage)
	outfile = HOST(2, optind + 1)		:f(usage)

	DIFFER(page)				:s(havepage)
	outfile BREAK('.') . page

havepage
	DIFFER(sect)				:s(havesect)
	outfile POS(0) BREAKX('.') '.' ANY(&DIGITS) . sect :f(usage)

havesect	
	snopea(infile, outfile, page, sect, fmt) :s(end)f(err)

usage	TERMINAL = 'Usage: snopea [opts] INFILE OUTFILE'
	TERMINAL = 'opts:'
	TERMINAL = '	--format roff|html'
	TERMINAL = '	--section 1..9'
	TERMINAL = '	--page PAGENAME'
err	&CODE = 1
END
