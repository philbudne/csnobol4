-include 'digest.sno'
	TEST = "This is a test string" CHAR(10)

	DEFINE("T(X)")			:(ET)
T	OUTPUT = DIGEST_HEX(X)		:(RETURN)
ET

	T(DIGEST_MD5(TEST))
	CTX = DIGEST_MD5_INIT()
	DIGEST_MD5_UPDATE(CTX, TEST)
	T(DIGEST_MD5_FINAL(CTX))

	T(DIGEST_SHA1(TEST))
	CTX = DIGEST_SHA1_INIT()
	DIGEST_SHA1_UPDATE(CTX, TEST)
	T(DIGEST_SHA1_FINAL(CTX))

	T(DIGEST_SHA224(TEST))
	CTX = DIGEST_SHA224_INIT()
	DIGEST_SHA224_UPDATE(CTX, TEST)
	T(DIGEST_SHA224_FINAL(CTX))

	T(DIGEST_SHA256(TEST))
	CTX = DIGEST_SHA256_INIT()
	DIGEST_SHA256_UPDATE(CTX, TEST)
	T(DIGEST_SHA256_FINAL(CTX))

	T(DIGEST_SHA384(TEST))
	CTX = DIGEST_SHA384_INIT()
	DIGEST_SHA384_UPDATE(CTX, TEST)
	T(DIGEST_SHA384_FINAL(CTX))

	T(DIGEST_SHA512(TEST))
	CTX = DIGEST_SHA512_INIT()
	DIGEST_SHA512_UPDATE(CTX, TEST)
	T(DIGEST_SHA512_FINAL(CTX))
END
