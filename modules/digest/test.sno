-include 'digest.sno'
	TEST = "This is a test string" CHAR(10)

	DEFINE("TD(ALG,STR)")			:(ET)
TD	OUTPUT = ALG
	OUTPUT = DIGEST_HEX(DIGEST(ALG,STR))	:(RETURN)
ET

* OpenSSL 1.0.2k-fips  26 Jan 2017 has:
*	md2 md4 md5 rmd160 sha1 
* OpenSSL 1.1.1c FIPS  28 May 2019 has:
*	blake2b512 blake2s256 gost md2 md4 md5 rmd160 sha1 sha224 sha256
*	sha3-224 sha3-256 sha3-384 sha3-512 sha384 sha512 sha512-224
*	sha512-256 shake128 shake256 sm3

	TD("md5", TEST)
	TD("sha1", TEST)
	TD("sha224", TEST)
	TD("sha256", TEST)
	TD("sha384", TEST)
	TD("sha512", TEST)
	TD("sha3-224", TEST)
	TD("sha3-256", TEST)
	TD("sha3-384", TEST)
	TD("sha3-512", TEST)
END
